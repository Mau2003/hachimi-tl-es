{
  "16470": "\"(¡En sus marcas, listos, fuera!)\"",
  "21101": "\"Oh (Umadacchi)\"",
  "23480": "\"Oh (Umapyoi, umapyoi)\"",
  "26670": "\"Oh (Sukidacchi)\"",
  "28070": "\"Oh (Umapoi)\"",
  "29480": "\"Uma uma umya unya—3, 2, 1, ¡lucha!\"",
  "32400": "\"El sol brilla, una carrera con buen tiempo (¡Sí!)\"",
  "33720": "\"Pasos de bebé, un poco nerviosa (¡Así que qué! ¡Así que qué!)\"",
  "35130": "\"1º, 2º, 3º, 4, 5 (Casi es mi turno ahora)\"",
  "37950": "\"Ojos brillantes, hora de empezar (¡Vamos!)\"",
  "39370": "\"Voy a volverme loca de nuevo hoy (¡Ay!)\"",
  "40950": "\"Llévalo al límite (¡Corta esas calorías!)\"",
  "42180": "\"Quiero comer arroz (¿Pero qué hay de mi peso de carrera?!)\"",
  "43600": "\"¿Qué hay de ella? (Waffles!)\\n¿Y de ella? (Bagels!)\"",
  "45020": "\"Bueno, bueno, el hambre se apoderó de todos (Recaída!)\"",
  "46480": "\"No derramar lágrimas (¡Bien!)\\nNo secarlas tampoco (¡Hey!)\"",
  "47830": "\"Probé la cosa del mercurio (¡No sanó!) (¿Qué?!)\"",
  "49380": "\"Solo yo voy a recibir un beso de la Diosa de la Victoria hoy\"",
  "54630": "\"Más allá del arcoíris iré\"",
  "57720": "\"Contra el viento, a través de la tierra\"",
  "60420": "\"Brillando una luz dentro de ti\"",
  "63200": "\"(pum-pum, pum-pum, pum-pum, pum-pum)\"",
  "66370": "\"¡Aquí viene tu amada!\"",
  "67750": "\"Tump tump salgo corriendo (¡Wu-huu!)\"",
  "70520": "\"Ba-dum buh-dum bajando por la hierba\"",
  "73350": "\"Nunca corrí una carrera como esta antes (3, 2, 1, ¡lucha!)\"",
  "78980": "\"Tump tump late mi corazón (¡Wu-huu!)\"",
  "81900": "\"Ba-dum buh-dum late solo por ti\"",
  "84780": "\"Voy a tocar esta melodía de nuevo hoy\"",
  "87370": "\"Feliz feliz querida—3, 2, 1, ¡vamos a luchar!\"",
  "90180": "\"Arriba arriba miel—3, 2, 1 (Oooh, ¡lucha!)\"",
  "93100": "\"Oh (Umadacchi)\"",
  "95950": "\"Oh (Umapyoi, umapyoi)\"",
